{
  "name": "@openflow/widget",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && npm run build:loader && npm run build:app",
    "build:app": "vite build",
    "build:loader": "vite build --mode loader",
    "format": "prettier --write \"**/*.{js,ts,tsx,json}\"",
    "lint": "eslint",
    "typecheck": "tsc -b --noEmit",
    "check": "npm run format && npm run lint && npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@openflow/shared-validation": "*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.0",
    "lucide-react": "^0.563.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.0",
    "shadcn": "^3.7.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
