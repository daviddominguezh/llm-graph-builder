# Redis: Upstash (cache only — credentials, media uploads)
UPSTASH_REDIS_REST_URL=<your-upstash-redis-rest-url>
UPSTASH_REDIS_REST_TOKEN=<your-upstash-redis-rest-token>

# Redis Cloud (pub/sub, locking, rate limiting, notifications)
REDIS_URL=redis://default:<password>@<host>:<port>

# Messaging: WhatsApp
WHATSAPP_APP_SECRET=<your-whatsapp-app-secret>
WHATSAPP_VERIFY_TOKEN=<your-whatsapp-verify-token>

# Messaging: Instagram
INSTAGRAM_APP_SECRET=<your-instagram-app-secret>
INSTAGRAM_VERIFY_TOKEN=<your-instagram-verify-token>

# Messaging: Auth
MESSAGING_MASTER_API_KEY=<your-messaging-api-key>

# Meta/Facebook App (WhatsApp Business)
