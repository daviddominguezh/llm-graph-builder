{
  "name": "@daviddh/graph-runner-backend",
  "version": "1.0.0",
  "description": "Backend server for LLM graph runner with MCP support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "graph-runner-backend": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --out-dir dist --clean",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,ts,json}\"",
    "check": "npm run format && npm run lint && npm run typecheck",
    "start": "node dist/index.js",
    "dev": "tsx watch --env-file=.env src/index.ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.26",
    "@daviddh/graph-types": "*",
    "@daviddh/llm-graph-runner": "*",
    "@supabase/supabase-js": "^2.99.0",
    "@types/multer": "^2.1.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jose": "^6.2.1",
    "multer": "^2.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@flydotio/dockerfile": "^0.7.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.27",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.51.0"
  }
}
